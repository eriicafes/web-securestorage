{
  "name": "web-securestorage",
  "version": "0.1.0",
  "description": "Web Secure Storage",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc && tsdown src/index.ts --format esm,cjs",
    "release": "pnpm run build && changeset publish",
    "watch": "vitest",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "browser",
    "securestorage",
    "localstorage"
  ],
  "author": "Eric Afes <eriicafes@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eriicafes/securestorage.git"
  },
  "bugs": {
    "url": "https://github.com/eriicafes/securestorage/issues"
  },
  "homepage": "https://github.com/eriicafes/securestorage#readme",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.9.0",
      "onFail": "download"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "tsdown": "^0.22.8",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}